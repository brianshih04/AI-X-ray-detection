# Environment configuration
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chestxpert
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/chestxpert

# JWT
JWT_SECRET_KEY=change-me-in-production-use-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# Paths
IMAGE_STORAGE_PATH=/data/nih-chest-xrays/images
CSV_DATA_PATH=/data/nih-chest-xrays

# Model
DEFAULT_MODEL_VERSION=densenet121-v1.0
CONFIDENCE_THRESHOLD=0.5

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10